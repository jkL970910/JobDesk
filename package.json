{
  "name": "jobdesk-schemas",
  "version": "0.1.0",
  "private": true,
  "description": "Job Search Copilot — canonical Zod schemas (source of truth). JSON Schema is generated.",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "next typegen && tsc --noEmit",
    "test": "vitest --run",
    "test:integration": "JOBDESK_RUN_DB_INTEGRATION=true vitest --run tests/*.integration.test.ts",
    "gen:jsonschema": "tsx scripts/generate-json-schema.ts",
    "ai:smoke:jd": "tsx scripts/smoke-jd-analysis.ts",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "mammoth": "^1.12.0",
    "next": "^15.5.19",
    "pdf-parse": "^2.4.5",
    "pg": "^8.21.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/node": "22.10.2",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.10",
    "tsx": "4.19.2",
    "typescript": "5.6.3",
    "vitest": "2.1.8",
    "zod-to-json-schema": "3.23.5"
  }
}
